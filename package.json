{
  "name": "morning-macro-brief",
  "version": "1.0.0",
  "description": "Sends a Morning Macro Brief Adaptive Card to Microsoft Teams every weekday at 08:30 AM GMT",
  "main": "morningMacroBrief.js",
  "scripts": {
    "start:master": "node masterBrief.js",
    "test:master": "node -e \"require('./masterBrief').sendConsolidatedMorningBrief().then(()=>process.exit())\"",
    "start:afternoon": "node afternoonDocBrief.js",
    "test:afternoon": "node -e \"require('./afternoonDocBrief').sendAfternoonDocBrief().then(()=>process.exit())\"",
    "test:fetch": "node -e \"require('./helpers/fetchOhlc').fetchAndCompute().then(d=>console.log(JSON.stringify(d,null,2))).catch(console.error)\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.2.0",
    "docx": "^9.6.1",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "xlsx": "^0.18.5"
  }
}
